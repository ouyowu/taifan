}

export async function generateMetadata({
  params,
}: {
  params: Promise<{ slug: string }>;
}): Promise<Metadata> {
  const { slug } = await params;
  const detail = await getStarDetail(slug);

  if (!detail) {
    return buildPageMetadata({
      title: "明星资料",
      description: "查看泰国明星的中文资料、近期活动和最新动态。",
      path: `/stars/${slug}`,
    });
  }

  const { star, events, news } = detail;

  return buildPageMetadata({
    title: `${star.nameEn} | 明星资料`,
    description: `${star.nameCn} / ${star.nameEn} 的中文追星入口，当前聚合活动 ${events.length} 条、动态 ${news.length} 条。保留原文名、品牌名和活动标题，方便继续搜索与核对。`,
    path: `/stars/${star.slug}`,
    image: star.coverUrl || star.avatarUrl,
  });
}
