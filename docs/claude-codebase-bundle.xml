                  </div>
                  <div className="grid gap-2 sm:grid-cols-3 md:gap-3">
                    <div className="rounded-[18px] bg-[#fafafa] p-3 md:rounded-[22px] md:p-4">
                      <p className="font-sans text-[10px] uppercase tracking-[0.16em] text-[#6d7b7e]">City</p>
