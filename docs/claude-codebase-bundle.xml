    return {
      key: `${index}-${label}`,
      label,
      isOther: day < 1 || day > 31,
      isToday: day === 18,
      dots: Math.min(eventCount, 3),
    };
  });

  const upcomingMonths = upcomingEvents.reduce<
    Array<{
      key: string;
      label: string;
      events: typeof upcomingEvents;
