                >
                  <div className="flex items-center gap-3">
                    <div className="relative h-[58px] w-[46px] overflow-hidden rounded-[16px] border border-[#e8e8e8] bg-white">
                      {star?.coverUrl ? (
                        <Image
                          src={star.coverUrl}
                          alt={star.nameEn}
                          fill
                          className="object-cover"
                          style={{ objectPosition: getImageObjectPosition(star.coverUrl, "poster") }}
                        />
                      ) : null}
                    </div>
                    <div>
                      <p className="font-en text-[18px] font-black tracking-[-0.03em] text-[#1c1c1e]">{star?.nameEn ?? "Thai star"}</p>
                      <p className="font-cn mt-1 text-[11px] text-[#6d7b7e]">本周先追 0{index + 1}</p>
                    </div>
                  </div>
                  <p className="font-cn mt-4 text-[14px] font-bold leading-[1.8] text-[#111111]">{event.summary}</p>
                  <p className="font-en mt-3 text-[10px] text-[#6d7b7e]">{event.title}</p>
                  <div className="mt-4 flex flex-wrap gap-2">
                    <span
                      className="font-cn rounded-full px-3 py-1 text-[11px] text-[#6d7b7e]"
                      style={{ backgroundColor: warmTones[index % warmTones.length] }}
                    >
                      {event.ticketStatus}
                    </span>
                    <span className="font-cn rounded-full bg-[#f4f1ec] px-3 py-1 text-[11px] text-[#6d7b7e]">{event.city}</span>
                  </div>
                </Link>
              ))}
            </div>
          </section>
        ) : null}

        {!showEmptyState ? (
        <div className="grid gap-4 md:gap-5">
          {visibleEvents.map((event, index) => {
            const date = new Date(event.startsAt);
            const starNames = event.starSlugs.map((slug) => starsMap.get(slug)?.nameCn ?? slug).join(" / ");
            const posterStar = stars.find((star) => event.starSlugs.includes(star.slug));

            return (
              <Link
                key={event.slug}
                href={`/events/${event.slug}`}
                className="grid gap-3 rounded-[28px] border border-[#e8e8e8] bg-white p-3 shadow-[0_2px_16px_rgba(0,0,0,0.07)] transition hover:-translate-y-0.5 md:grid-cols-[210px_1fr] md:gap-4 md:rounded-[36px] md:p-4"
              >
                <div className="relative overflow-hidden rounded-[22px] md:rounded-[28px]" style={{ backgroundColor: warmTones[index % warmTones.length] }}>
                  <div className="relative h-[240px] overflow-hidden rounded-[18px] md:h-[280px] md:rounded-[24px]">
                    {posterStar?.coverUrl ? (
                      <Image
                        src={posterStar.coverUrl}
                        alt={posterStar.nameEn}
                        fill
                        className="object-cover"
                        style={{ objectPosition: getImageObjectPosition(posterStar.coverUrl, "poster") }}
                      />
                    ) : null}
                    <div className="absolute inset-0 bg-[linear-gradient(180deg,rgba(16,35,39,0.02)_0%,rgba(16,35,39,0.68)_100%)]" />
                    <div className="absolute inset-x-0 bottom-0 p-4">
                      <p className="font-en text-[24px] font-black tracking-[-0.04em] text-white">{posterStar?.nameEn ?? "Thai star"}</p>
                      <p className="font-cn mt-1 text-[12px] text-white/82">{starNames}</p>
                    </div>
                  </div>
                </div>
                <div className="flex flex-col justify-between gap-3 p-1 md:gap-4 md:p-2">
                  <div>
                    <div className="mb-3 flex flex-wrap gap-2">
                      <span
                        className="font-en rounded-full px-3 py-1 text-[11px] font-black tracking-[0.08em] text-[#1c1c1e]"
                        style={{ backgroundColor: warmTones[index % warmTones.length] }}
                      >
                        {format(date, "dd MMM", { locale: zhCN }).toUpperCase()}
                      </span>
                      <span className="font-cn rounded-full bg-[#fff4ee] px-3 py-1 text-[11px] text-[#f07030]">{event.ticketStatus}</span>
                      <span className="font-cn rounded-full bg-[#f4f1ec] px-3 py-1 text-[11px] text-[#6d7b7e]">
                        {event.sourceLabel || "站内整理来源"}
                      </span>
                    </div>
                    <p className="font-cn text-[16px] font-bold leading-[1.6] text-[#1c1c1e] md:text-[20px]">{event.summary}</p>
                    <p className="font-en mt-2 text-[10px] text-[#6d7b7e] md:mt-3 md:text-[11px]">{event.title}</p>
                    <p className="font-en mt-1 text-[10px] text-[#6d7b7e] md:mt-2 md:text-[11px]">
