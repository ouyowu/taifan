            <TableRow className="border-white/10">
              <TableHead>标题</TableHead>
              <TableHead>时间</TableHead>
              <TableHead>状态</TableHead>
              <TableHead>操作</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {events.map((event) => (
              <TableRow key={event.slug} className="border-white/10">
                <TableCell>
                  <div className="space-y-2">
