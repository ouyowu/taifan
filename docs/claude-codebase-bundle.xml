  return createServerClient(url, anonKey, {
    global: {
      fetch: (input, init) =>
        fetch(input, {
          ...init,
          cache: "no-store",
          next: { revalidate: 0 },
        }),
    },
    cookies: {
      getAll() {
        return cookieStore.getAll();
      },
      setAll() {
        // No-op for MVP server components.
      },
    },
  });
}
