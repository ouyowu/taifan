                <span className="font-cn rounded-full bg-[#fafafa] px-3 py-2 text-[12px] text-[#6e6e73]">
                  {star.agency}
                </span>
              </div>

              <div className="space-y-4">
                <div>
                  <h1 className="lattice-title text-[38px] leading-[0.98] md:text-[58px] xl:text-[68px]">{star.nameEn}</h1>
                  <div className="mt-3 flex flex-wrap items-center gap-x-3 gap-y-2">
                    <p className="font-cn text-[19px] font-bold text-[#111111] md:text-[24px]">{star.nameCn}</p>
                    <span className="font-sans text-[11px] uppercase tracking-[0.18em] text-[#f07030]">{star.fandomName}</span>
