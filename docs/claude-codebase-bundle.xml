  draftQueueMode,
  currentDraftQueueJob,
  currentDraftQueueJobsLength,
  draftQueueIndex,
  pendingSplitNewsCount,
  submittingEvent,
  eventForm,
  onSubmit,
  onSetPublishAfterSave,
  onCancelEdit,
  onRetreatDraftQueue,
  onAdvanceDraftQueue,
