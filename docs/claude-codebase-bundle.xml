  { kind: "写真集", price: "¥299", badge: "NEW" },
  { kind: "亚克力立牌", price: "¥129", badge: "HOT" },
  { kind: "随机小卡", price: "¥49", badge: "LIMITED" },
  { kind: "应援套组", price: "¥239", badge: "PREORDER" },
];

