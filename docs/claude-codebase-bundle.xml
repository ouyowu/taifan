<file path="src/app/calendar/page.tsx">
import Link from "next/link";
import Image from "next/image";
import type { Metadata } from "next";
import { format } from "date-fns";
import { zhCN } from "date-fns/locale";

import { SiteShell } from "@/components/layout/site-shell";
import { listEvents, listStars } from "@/lib/data";
import { getImageObjectPosition } from "@/lib/image-focus";
import { buildPageMetadata } from "@/lib/metadata";

export const metadata: Metadata = buildPageMetadata({
  title: "活动日历",
  description: "查看泰国明星活动日历，集中了解时间、场馆、票务状态和官方来源，用中文先看懂，再用原文去搜票和核对。",
  path: "/calendar",
});

export default async function CalendarPage({
  searchParams,
}: {
  searchParams?: Promise<{ source?: string }>;
}) {
  const [events, stars] = await Promise.all([listEvents(), listStars()]);
  const params = (await searchParams) ?? {};
  const sourceFilter = params.source === "official" ? "official" : "all";
  const visibleEvents = sourceFilter === "official" ? events.filter((event) => Boolean(event.sourceLabel)) : events;
  const showEmptyState = visibleEvents.length === 0;
  const starsMap = new Map(stars.map((star) => [star.slug, star]));
  const warmTones = ["#fff4ee", "#f8f0ff", "#f0f8ff", "#f5fff0"];
  const starterEvents = visibleEvents.slice(0, 3).map((event) => ({
    event,
    star: stars.find((item) => event.starSlugs.includes(item.slug)),
  }));

  return (
    <SiteShell>
      <section className="page-shell mx-auto max-w-[1440px] py-10 md:py-16">
        <div className="mb-7 flex flex-col gap-4 md:mb-8 md:flex-row md:items-end md:justify-between md:gap-5">
          <div>
            <p className="font-sans text-[10px] uppercase tracking-[0.18em] text-[#f07030]">Calendar</p>
            <h1 className="lattice-title mt-3 text-[38px] leading-[0.98] md:mt-4 md:text-[76px]">Never miss a moment.</h1>
            <p className="font-cn mt-3 text-[22px] font-bold text-[#111111]">活动日历</p>
            <p className="font-cn mt-3 max-w-[720px] text-[13px] leading-[1.8] text-[#6d7b7e] md:mt-4 md:text-[15px] md:leading-[1.85]">
              先聚合粉丝最关心的时间、地点、票务状态和可信度。活动官方标题、商场名、场馆名尽量保留原文，中文负责解释清楚这场活动是什么。
            </p>
          </div>
          <div className="font-cn text-[13px] text-[#6d7b7e]">当前展示 {visibleEvents.length} 条活动</div>
        </div>

        <div className="mb-7 flex flex-wrap gap-2 md:mb-8">
          <Link
            href="/calendar"
            className={`font-cn rounded-full px-4 py-2 text-[13px] ${sourceFilter === "all" ? "bg-[#1c1c1e] text-white" : "bg-[#f4f1ec] text-[#6d7b7e]"}`}
          >
            全部
          </Link>
          <Link
            href="/calendar?source=official"
            className={`font-cn rounded-full px-4 py-2 text-[13px] ${sourceFilter === "official" ? "bg-[#fff4ee] text-[#f07030]" : "bg-[#f4f1ec] text-[#6d7b7e]"}`}
          >
            官方来源
          </Link>
          <span className="font-cn rounded-full bg-[#f4f1ec] px-4 py-2 text-[13px] text-[#6d7b7e]">应援活动</span>
        </div>

        {showEmptyState ? (
          <section className="mb-8 rounded-[28px] border border-[#f1d8cf] bg-[#fff7f3] p-5 shadow-[0_18px_45px_rgba(16,35,39,0.04)] md:mb-10 md:rounded-[34px] md:p-6">
            <p className="font-sans text-[10px] uppercase tracking-[0.18em] text-[#c1725a]">Calendar check</p>
            <h2 className="lattice-title mt-3 text-[28px] md:text-[40px]">No events published yet.</h2>
            <p className="font-cn mt-3 max-w-[760px] text-[13px] leading-[1.8] text-[#7a6f69] md:text-[14px] md:leading-[1.85]">
              当前活动日历还没有可展示的真实活动。上线前请先确认 migration 已执行，并至少写入 1 到 3 条活动测试数据，避免前台首屏直接空掉。
            </p>
          </section>
        ) : null}

        {starterEvents.length ? (
          <section className="mb-8 rounded-[28px] border border-[#e8e8e8] bg-white p-5 shadow-[0_2px_16px_rgba(0,0,0,0.07)] md:mb-10 md:rounded-[36px] md:p-8">
            <div className="mb-5 md:mb-6">
              <p className="font-sans text-[10px] uppercase tracking-[0.18em] text-[#f07030]">Starter events</p>
              <h2 className="lattice-title mt-3 text-[28px] md:text-[42px]">Watch these first.</h2>
              <p className="font-cn mt-3 max-w-[760px] text-[13px] leading-[1.8] text-[#6d7b7e] md:text-[14px] md:leading-[1.85]">
                如果你不是要把整张日历从头翻完，先看这几场最值。它们通常最能代表这一周最值得追的活动线：票务、品牌公开露出、见面会，或者最容易带新粉快速进入状态的场次。
              </p>
            </div>
            <div className="grid gap-3 lg:grid-cols-3 md:gap-4">
              {starterEvents.map(({ event, star }, index) => (
                <Link
